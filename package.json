{
  "name": "icv-dash",
  "version": "0.1.0",
  "private": true,
  "description": "Dashboard de doações que consome a API de cobranças do Asaas e alimenta um banco PostgreSQL via cron jobs.",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "sync": "tsx scripts/sync.ts",
    "db:deploy": "prisma db push --skip-generate --accept-data-loss && tsx prisma/seed.ts",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "tsx prisma/seed.ts",
    "prisma:studio": "prisma studio"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@next/env": "^14.2.35",
    "@prisma/client": "^5.22.0",
    "date-fns": "^3.6.0",
    "next": "^14.2.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.12.7"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.35",
    "prisma": "^5.22.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  }
}
