# ==========================================================================
# icv-dash — variáveis de ambiente (EXEMPLO)
# ==========================================================================

# --- Banco de dados ------------------------------------------------------
# No deploy (docker-compose) o banco é DEDICADO e a DATABASE_URL é montada
# automaticamente a partir de POSTGRES_*. Você só precisa definir a senha:
POSTGRES_USER="icv"
POSTGRES_PASSWORD="defina-uma-senha-forte"
POSTGRES_DB="icvdash"

# Para rodar LOCALMENTE (npm run dev) aponte para um Postgres seu:
DATABASE_URL="postgresql://icv:senha@localhost:5432/icvdash?schema=public"

# --- API Asaas -----------------------------------------------------------
ASAAS_API_URL="https://api.asaas.com/v3"
# A chave começa com `$`. No .env local escape como \$ ; no painel do Dokploy
# (compose) escape como $$ . Ex.: \$aact_prod_000...  /  $$aact_prod_000...
ASAAS_API_KEY="coloque_sua_chave_asaas"
# Projeto atribuído às doações vindas da API (a key é da conta ICV):
ASAAS_PROJECT="Cruz da Vida"

# --- Cron / sincronização ------------------------------------------------
# O cron do Asaas só roda se SYNC_ENABLED=true. A carga inicial vem das planilhas.
SYNC_ENABLED="false"
SYNC_LOOKBACK_DAYS="35"
CRON_SECRET="gere_um_segredo_aleatorio"

# --- Webhook Asaas -------------------------------------------------------
ASAAS_WEBHOOK_TOKEN="defina-um-token-de-webhook"

# --- Login Admin ---------------------------------------------------------
ADMIN_EMAIL="admin@cruzdavida.org"
ADMIN_PASSWORD="defina-uma-senha-forte"
AUTH_SECRET="gere_com_openssl_rand_hex_32"
