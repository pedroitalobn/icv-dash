# ==========================================================================
# icv-dash — variáveis de ambiente (EXEMPLO)
# Copie este arquivo para `.env` e preencha com os valores reais.
# ==========================================================================

# --- Banco de dados PostgreSQL -------------------------------------------
# Formato: postgresql://USUARIO:SENHA@HOST:PORTA/BANCO
DATABASE_URL="postgresql://usuario:senha@host:5432/banco?schema=public"

# --- API Asaas -----------------------------------------------------------
# Ambiente: use a URL de sandbox para testes e a de produção quando for ao ar.
#   Sandbox:    https://sandbox.asaas.com/api/v3
#   Produção:   https://api.asaas.com/v3
ASAAS_API_URL="https://sandbox.asaas.com/api/v3"

# Chave de API do Asaas (Configurações da conta > Integrações > Chave de API).
ASAAS_API_KEY="coloque_sua_chave_asaas_aqui"

# --- Cron / sincronização ------------------------------------------------
# Segredo usado para proteger o endpoint /api/cron/sync.
# O agendador (Vercel Cron / crontab) deve enviar:  Authorization: Bearer <CRON_SECRET>
CRON_SECRET="gere_um_segredo_aleatorio_forte"

# Quantos dias para trás a sincronização incremental deve buscar (padrão: 35).
SYNC_LOOKBACK_DAYS="35"
